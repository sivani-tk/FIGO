# =============================================================================
# FIGO — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# The app falls back to mock/offline services when keys are absent.
# =============================================================================

# --- OpenWeatherMap --------------------------------------------------------
# Get your key at: https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=

# --- Open-Meteo (no key needed — free, no auth) ----------------------------
# Used as primary weather provider (always active)
# Docs: https://open-meteo.com/

# --- OpenAI ----------------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# --- Google Maps -----------------------------------------------------------
# Get your key at: https://console.cloud.google.com
# Enable: Maps JavaScript API, Directions API, Places API
VITE_GOOGLE_MAPS_API_KEY=

# --- Google OAuth (Client ID) ----------------------------------------------
# Get at: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=

# --- ExchangeRate API ------------------------------------------------------
# Get your key at: https://www.exchangerate-api.com/
VITE_EXCHANGE_RATE_API_KEY=

# --- Unsplash --------------------------------------------------------------
# Get your key at: https://unsplash.com/developers
VITE_UNSPLASH_ACCESS_KEY=

# --- Pexels ----------------------------------------------------------------
# Get your key at: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=

# =============================================================================
# NOTE: All services have built-in mock fallbacks.
# The app runs fully in demo mode without any keys.
# =============================================================================
